# ----------------------------------------------------------------------
# Frontend → Backend connection
# ----------------------------------------------------------------------
# Copy this file to .env and set values for your environment.
#
# Development (with Vite proxy):
#   Leave empty or set to empty string so requests go to same origin (localhost:3030).
#   Vite will forward /api/* to the proxy target (see vite.config.js).
#
# Production (or dev against a remote API):
#   Set to your backend base URL, e.g. https://your-api.com/api
#   No trailing slash. All API paths (e.g. /api/login) are appended to this.
# ----------------------------------------------------------------------

VITE_APP_BASE_URL=
